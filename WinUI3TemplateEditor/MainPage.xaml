<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinUI3TemplateEditor.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppSidebarBrush}">

    <Grid Background="{StaticResource AppSidebarBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            x:Name="SidebarPanel"
            Grid.Column="0"
            Padding="16,58,16,18"
            BorderBrush="{StaticResource AppSidebarBorderBrush}"
            BorderThickness="0"
            Background="{StaticResource AppSidebarBrush}">
            <Grid RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock
                        Text="Editor de Plantillas"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    <TextBlock
                        Text="Selecciona un documento, edita sus campos y exporta una copia nueva."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="8">
                    <TextBlock
                        Text="Documento"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontWeight="SemiBold" />
                    <ComboBox
                        x:Name="DocumentsCombo"
                        HorizontalAlignment="Stretch"
                        DisplayMemberPath="Label"
                        PlaceholderText="Seleccionar documento"
                        SelectionChanged="DocumentsCombo_SelectionChanged" />
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="8">
                    <Border
                        Height="3"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="2" />

                    <Button
                        x:Name="ExportButton"
                        HorizontalAlignment="Stretch"
                        Click="ExportButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74E;" />
                            <TextBlock Text="Exportar editado" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="OpenFolderButton"
                        HorizontalAlignment="Stretch"
                        Click="OpenFolderButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE838;" />
                            <TextBlock Text="Abrir carpeta de salida" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="CheckUpdatesButton"
                        HorizontalAlignment="Stretch"
                        Click="CheckUpdatesButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE896;" />
                            <TextBlock Text="Buscar actualizacion" />
                        </StackPanel>
                    </Button>
                    <InfoBar
                        x:Name="StatusBar"
                        IsOpen="True"
                        Severity="Informational"
                        Message="Carga una plantilla para empezar." />
                </StackPanel>

                <ScrollViewer
                    Grid.Row="3"
                    VerticalScrollBarVisibility="Hidden"
                    VerticalScrollMode="Enabled">
                    <StackPanel x:Name="FieldsPanel" Spacing="10" />
                </ScrollViewer>
            </Grid>
        </Border>

        <Border
            x:Name="PreviewShell"
            Grid.Column="1"
            Margin="0,14,0,0"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0"
            Background="{StaticResource AppViewportBrush}"
            CornerRadius="12,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Padding="22,16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    Background="{StaticResource AppViewportHeaderBrush}"
                    CornerRadius="12,0,0,0">
                    <Grid>
                        <StackPanel>
                            <TextBlock
                                Text="Vista previa"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <TextBlock
                                x:Name="PreviewSubtitle"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Sin documento seleccionado" />
                        </StackPanel>

                        <Border
                            Padding="8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="{StaticResource AppPanelBrush}"
                            CornerRadius="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="ZoomOutButton_Click" Content="-" />
                                <TextBlock
                                    x:Name="ZoomLabel"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="100%" />
                                <Button Click="ZoomInButton_Click" Content="+" />
                                <Button Click="ResetZoomButton_Click" Content="Restablecer" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="1"
                    Background="{StaticResource AppViewportBrush}"
                    CornerRadius="0,0,0,12">
                    <ScrollViewer
                        Background="Transparent"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
                        <Grid Padding="42">
                            <Border
                                x:Name="PreviewPage"
                                Width="794"
                                Height="1123"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                Background="White"
                                CornerRadius="2">
                                <Grid>
                                    <Image
                                        x:Name="PreviewImage"
                                        Stretch="Fill" />
                                    <StackPanel
                                        x:Name="PreviewContent"
                                        Padding="54"
                                        Spacing="14"
                                        Visibility="Collapsed" />
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Button
            x:Name="SidebarToggleButton"
            Grid.ColumnSpan="2"
            Width="32"
            Height="32"
            Margin="10,10,0,0"
            Padding="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{StaticResource AppPanelBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            Click="SidebarToggleButton_Click"
            ToolTipService.ToolTip="Ocultar barra lateral    Ctrl+B">
            <Button.KeyboardAccelerators>
                <KeyboardAccelerator
                    Key="B"
                    Modifiers="Control"
                    Invoked="SidebarToggleKeyboard_Invoked" />
            </Button.KeyboardAccelerators>
            <FontIcon
                x:Name="SidebarToggleIcon"
                FontSize="14"
                Glyph="&#xE700;" />
        </Button>
    </Grid>
</Page>
